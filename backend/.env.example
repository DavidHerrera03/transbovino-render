# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=transbovino

# Frontend
# En Render NO uses localhost. Usa la URL real de tu frontend desplegado.
FRONTEND_URL=https://transbovino-frontend.onrender.com
RESET_BASE_URL=https://transbovino-frontend.onrender.com

# Recuperacion de contrasena en Render gratis - recomendado
# La API key real se configura en Render > Environment del BACKEND.
# No subas tu API key real a GitHub.
RESEND_API_KEY= re_5kAbaod7_HPQ2qzT5mdAegx3sxs1GQnjr
EMAIL_FROM=TransBovino <onboarding@resend.dev>

# Recuperacion de contrasena por SMTP - opcional
# Usar solo en local o en un plan/servidor que permita salida SMTP.
# En Render gratis Gmail SMTP por el puerto 587 normalmente no funciona.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Firebase / Google Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET_NAME=
FIREBASE_CREDENTIALS=
FIREBASE_STORAGE_BUCKET=

# Pool de conexiones SQLAlchemy / Render
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300
