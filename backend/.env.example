# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=transbovino

# Frontend
FRONTEND_URL=https://transbovino-frontend.onrender.com
RESET_BASE_URL=https://transbovino-frontend.onrender.com

# Correo para recuperar contraseña en Render usando Resend
# La llave real NO se sube a GitHub. Va en Render > Environment.
RESEND_API_KEY=
EMAIL_FROM=TransBovino <onboarding@resend.dev>

# SMTP solo como respaldo/local. En Render gratis no funciona bien por bloqueo de puertos SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Firebase / Google Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET_NAME=

# Pool de conexiones SQLAlchemy / Render
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

